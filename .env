# Node Environment
# Set to "production" for production, "development" for local development
NODE_ENV=production

# Server Configuration
PORT=4000
HOST=0.0.0.0


EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=zyspirit710@gmail.com
EMAIL_PASSWORD=

# Database Configuration (Supabase / PostgreSQL)
# Get these from your Supabase project: Settings -> API
# SUPABASE_SERVICE_ROLE_KEY is a server-side secret. Never expose it to a frontend.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# JWT Secret
JWT_SECRET=secret
JWT_EXPIRES_IN=1d

# Stripe Configuration
# Stripe Secret Key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# CORS Configuration (optional - will use defaults based on NODE_ENV)
PROD_CORS_ORIGIN=https://manabou.co.jp,https://www.manabou.co.jp
# DEV_CORS_ORIGIN=http://localhost:5173,https://manabou.co.jp
